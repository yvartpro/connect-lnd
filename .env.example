# .env

# --- LND gRPC Connection Details ---
# This is the address (host and port) of your LND node's gRPC interface.
# Default for local nodes is often 'localhost:10001'
LND_GRPC_HOST=<host:port of your LND node's gRPC interface>

# --- Base64 Encoded Credentials (REQUIRED) ---
# You must provide the base64-encoded strings of your macaroon and cert files.
# See README.md for instructions on how to generate these.
LND_MACAROON_BASE64=<base64-encoded macaroon string>
LND_TLS_CERT_BASE64=<base64-encoded TLS certificate string>

# --- Database Configuration ---
# MySQL connection settings used by Sequelize.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# --- Server Configuration ---
# The port your Express API server will run on.
PORT=5003